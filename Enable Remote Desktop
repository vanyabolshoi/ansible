    - name: Allow RDP port 3389 firewall
      ansible.windows.win_shell: |
        netsh advfirewall firewall show rule name="Allow RDP 3389" >nul 2>&1
        if %errorlevel% neq 0 netsh advfirewall firewall add rule name="Allow RDP 3389" dir=in action=allow protocol=TCP localport=3389
      args:
        executable: cmd
      register: rdp_firewall
      failed_when: false
