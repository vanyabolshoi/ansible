---
- name: SQL Server Backup with FreeFileSyncPortable
  hosts: all
  gather_facts: no
  serial: 20
  strategy: linear
  any_errors_fatal: false
  max_fail_percentage: 100
  ignore_unreachable: yes

  vars:
    backup_server: "172.16.11.226"
    backup_share: "\\\\172.16.11.226\\BackupSQL"
    backup_user: "172.16.11.226\\Администратор"
    backup_pass: "Pharmacia_"

  tasks:
    - name: Create SQL backup and copy with FreeFileSyncPortable
      ansible.windows.win_shell: |
        function Write-BackupStatus {
          param(
            [string]$Status,
            [string]$Text,
            [string]$Database = ""
          )

          $statusDir = "{{ backup_share }}\_status"

          if (!$Database) {
            $Database = "unknown_{{ inventory_hostname }}"
          }

          try {
            New-Item -ItemType Directory -Path $statusDir -Force | Out-Null

            $statusFile = "$statusDir\$Database.json"

            $s = @{
              database = $Database
              computer = $env:COMPUTERNAME
              host = "{{ inventory_hostname }}"
              status = $Status
              text = $Text
              time = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
            }

            $s | ConvertTo-Json -Depth 5 | Out-File $statusFile -Encoding UTF8
          } catch {
            Write-Host "Cannot write status file: $($_.Exception.Message)"
          }
        }

        $db = $null

        try {
          cmd /c "net use {{ backup_share }} /delete /y >nul 2>&1"
          net use {{ backup_share }} /user:{{ backup_user }} {{ backup_pass }} /persistent:no

          if (!(Test-Path "{{ backup_share }}")) {
            Write-BackupStatus "error" "❌ Ошибка" "unknown_{{ inventory_hostname }}"
            throw "Cannot access backup share: {{ backup_share }}"
          }

          # Программа FreeFileSync используется только для этого backup-процесса,
          # поэтому в начале убиваем старые/зависшие процессы, чтобы не держали lock-файлы.
          Get-Process *FreeFileSync* -ErrorAction SilentlyContinue |
            Stop-Process -Force -ErrorAction SilentlyContinue
          Start-Sleep -Seconds 2

          $backupWorkDir = "C:\TEMPO"
          $freeWorkDir = "C:\FREE"

          New-Item -ItemType Directory -Path $backupWorkDir -Force | Out-Null
          New-Item -ItemType Directory -Path $freeWorkDir -Force | Out-Null

          # Полностью очищаем C:\TEMPO в начале работы.
          # Служебные файлы FreeFileSync храним только в C:\FREE.
          Get-ChildItem $backupWorkDir -Force -ErrorAction SilentlyContinue |
            Remove-Item -Recurse -Force -ErrorAction SilentlyContinue

          $ffsDir = "$freeWorkDir\FreeFileSyncPortable"
          $ffs = ""

          $foundFfs = Get-ChildItem $ffsDir -Recurse -Filter "FreeFileSyncPortable.exe" -ErrorAction SilentlyContinue | Select-Object -First 1

          if (!$foundFfs) {
            Write-Host "FreeFileSyncPortable not found. Deploying..."

            $zip = "$freeWorkDir\FreeFileSyncPortable.zip"
            $zipUrl = "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/FreeFileSyncPortable.zip"

            if (Test-Path $ffsDir) {
              Remove-Item $ffsDir -Recurse -Force -ErrorAction SilentlyContinue
            }

            if (Test-Path $zip) {
              Remove-Item $zip -Force -ErrorAction SilentlyContinue
            }

            Invoke-WebRequest -Uri $zipUrl -OutFile $zip -UseBasicParsing

            if (!(Test-Path $zip)) {
              Write-BackupStatus "error" "❌ Ошибка" "unknown_{{ inventory_hostname }}"
              throw "FreeFileSyncPortable.zip was not downloaded"
            }

            New-Item -ItemType Directory -Path $ffsDir -Force | Out-Null
            Expand-Archive -Path $zip -DestinationPath $ffsDir -Force

            $foundFfs = Get-ChildItem $ffsDir -Recurse -Filter "FreeFileSyncPortable.exe" -ErrorAction SilentlyContinue | Select-Object -First 1
          }

          if (!$foundFfs) {
            Write-BackupStatus "error" "❌ Ошибка" "unknown_{{ inventory_hostname }}"
            throw "FreeFileSyncPortable.exe not found"
          }

          $ffs = $foundFfs.FullName
          Write-Host "FreeFileSyncPortable ready: $ffs"

          # Рабочие папки FreeFileSync/Portable держим только в C:\FREE,
          # чтобы sync.ffs_lock и служебные файлы не попадали в C:\TEMPO и BackupSQL.
          New-Item -ItemType Directory -Path "$freeWorkDir\Data" -Force | Out-Null
          New-Item -ItemType Directory -Path "$freeWorkDir\Data\Temp" -Force | Out-Null
          New-Item -ItemType Directory -Path "$freeWorkDir\Data\settings" -Force | Out-Null
          New-Item -ItemType Directory -Path "$ffsDir\Data" -Force | Out-Null
          New-Item -ItemType Directory -Path "$ffsDir\Data\Temp" -Force | Out-Null
          New-Item -ItemType Directory -Path "$ffsDir\Data\settings" -Force | Out-Null

          $env:TEMP = "$freeWorkDir\Data\Temp"
          $env:TMP  = "$freeWorkDir\Data\Temp"

          $sqlService = Get-Service |
            Where-Object { $_.Name -like "MSSQL$*" } |
            Select-Object -First 1

          if (!$sqlService) {
            Write-BackupStatus "error" "❌ Ошибка" "unknown_{{ inventory_hostname }}"
            throw "SQL Server service not found"
          }

          $sqlName = $sqlService.Name -replace "MSSQL\$",""
          $instance = ".\$sqlName"

          $dbInfo = sqlcmd -S "$instance" -h -1 -W -Q "
          SET NOCOUNT ON;
          SELECT TOP 1
            DB_NAME(database_id) + '|' + physical_name
          FROM sys.master_files
          WHERE type_desc = 'ROWS'
            AND DB_NAME(database_id) NOT IN ('master','model','msdb','tempdb')
            AND physical_name LIKE 'C:\DataSQL%'
          ORDER BY database_id;
          "

          $dbInfo = ($dbInfo | Where-Object { $_ -and $_.Trim() -ne "" } | Select-Object -First 1).Trim()

          if (!$dbInfo -or $dbInfo -notlike "*|*") {
            Write-BackupStatus "error" "❌ Ошибка" "unknown_{{ inventory_hostname }}"
            throw "Database not found by MDF path in C:\DataSQL"
          }

          $db = ($dbInfo -split "\|")[0].Trim()
          $mdfPath = ($dbInfo -split "\|")[1].Trim()

          Write-Host "Detected database: $db"
          Write-Host "Detected MDF: $mdfPath"

          $backupFile = "$backupWorkDir\$db.bak"
          $remoteBak = "{{ backup_share }}\$db.bak"

          # В C:\TEMPO оставляем только backup-файл.
          Get-ChildItem $backupWorkDir -File -ErrorAction SilentlyContinue |
            Where-Object { $_.Name -ne "$db.bak" } |
            Remove-Item -Force -ErrorAction SilentlyContinue

          # Все служебные файлы FreeFileSync держим в C:\FREE.
          $syncFile = "$freeWorkDir\Sync_$db.ffs_batch"
          $syncTemplate = "$freeWorkDir\SyncTemplate.ffs_batch"
          $syncUrl = "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/SyncSettings.ffs_batch"

          if (Test-Path $backupFile) {
            Remove-Item $backupFile -Force -ErrorAction SilentlyContinue
            Start-Sleep -Seconds 5
          }

          if (Test-Path $syncFile) {
            Remove-Item $syncFile -Force -ErrorAction SilentlyContinue
          }

          if (Test-Path $syncTemplate) {
            Remove-Item $syncTemplate -Force -ErrorAction SilentlyContinue
          }

          Invoke-WebRequest -Uri $syncUrl -OutFile $syncTemplate -UseBasicParsing

          if (!(Test-Path $syncTemplate)) {
            Write-BackupStatus "error" "❌ Ошибка" $db
            throw "SyncSettings.ffs_batch was not downloaded"
          }

          Copy-Item $syncTemplate $syncFile -Force

          if (!(Test-Path $syncFile)) {
            Write-BackupStatus "error" "❌ Ошибка" $db
            throw "Unique Sync_$db.ffs_batch was not created"
          }

          Write-BackupStatus "creating" "🔄 Создание backup" $db

          sqlcmd -S "$instance" -Q "ALTER DATABASE [$db] SET RECOVERY SIMPLE WITH NO_WAIT"
          sqlcmd -S "$instance" -Q "CHECKPOINT"
          sqlcmd -S "$instance" -Q "DBCC SHRINKDATABASE ([$db])"
          sqlcmd -S "$instance" -Q "BACKUP DATABASE [$db] TO DISK = '$backupFile' WITH FORMAT, INIT, COMPRESSION, NAME = 'Full Backup of $db', STATS = 10"

          if (!(Test-Path $backupFile)) {
            Write-BackupStatus "error" "❌ Ошибка" $db
            throw "Backup file not created: $backupFile"
          }

          # Перед копированием в C:\TEMPO должен быть только .bak.
          Get-ChildItem $backupWorkDir -File -ErrorAction SilentlyContinue |
            Where-Object { $_.Name -ne "$db.bak" } |
            Remove-Item -Force -ErrorAction SilentlyContinue

          Write-Host "Waiting for backup file to unlock..."
          Start-Sleep -Seconds 30

          Write-BackupStatus "copying" "📤 Копирование" $db

          # Перед запуском копирования ещё раз очищаем C:\TEMPO от всего, кроме текущего backup.
          Get-ChildItem $backupWorkDir -File -ErrorAction SilentlyContinue |
            Where-Object { $_.Name -ne "$db.bak" } |
            Remove-Item -Force -ErrorAction SilentlyContinue

          Write-Host "Starting FreeFileSyncPortable: $ffs $syncFile"
          Start-Process -FilePath $ffs -ArgumentList "`"$syncFile`"" -WorkingDirectory $freeWorkDir -Wait -NoNewWindow

          # Ждём появления файла на сервере до 15 минут.
          $timeout = 900
          $elapsed = 0
          while ($elapsed -lt $timeout) {
            if (Test-Path $remoteBak) {
              break
            }
            Start-Sleep -Seconds 5
            $elapsed += 5
          }

          if (!(Test-Path $remoteBak)) {
            Write-BackupStatus "error" "❌ Ошибка" $db
            throw "Remote backup not found after 15 minutes: $remoteBak"
          }

          $localSize = (Get-Item $backupFile).Length
          $remoteSize = (Get-Item $remoteBak).Length

          if ($localSize -ne $remoteSize) {
            Write-BackupStatus "error" "❌ Ошибка" $db
            throw "Backup size mismatch. Local=$localSize Remote=$remoteSize"
          }

          $now = Get-Date
          (Get-Item $remoteBak).CreationTime = $now
          (Get-Item $remoteBak).LastWriteTime = $now
          (Get-Item $remoteBak).LastAccessTime = $now

          $metaDir = "{{ backup_share }}\_meta"
          New-Item -ItemType Directory -Path $metaDir -Force | Out-Null

          $dbFiles = sqlcmd -S "$instance" -h -1 -W -Q "
          SET NOCOUNT ON;
          SELECT physical_name
          FROM sys.master_files
          WHERE database_id = DB_ID('$db');
          "

          $mdfSizeMb = 0
          $logSizeMb = 0

          foreach ($filePath in $dbFiles) {
            $filePath = $filePath.Trim()
            if ($filePath -and (Test-Path $filePath)) {
              $sizeMb = [math]::Round(((Get-Item $filePath).Length / 1MB), 2)

              if ($filePath.ToLower().EndsWith(".ldf")) {
                $logSizeMb += $sizeMb
              } else {
                $mdfSizeMb += $sizeMb
              }
            }
          }

          $dbSizeMb = [math]::Round(($mdfSizeMb + $logSizeMb), 2)
          $bakSizeMb = [math]::Round(((Get-Item $remoteBak).Length / 1MB), 2)

          $compression = 0
          if ($dbSizeMb -gt 0) {
            $compression = [math]::Round((100 - (($bakSizeMb / $dbSizeMb) * 100)), 1)
          }

          $meta = @{
            database     = $db
            computer     = $env:COMPUTERNAME
            host         = "{{ inventory_hostname }}"
            backup_time  = $now.ToString("yyyy-MM-dd HH:mm:ss")
            mdf_size_mb  = $mdfSizeMb
            log_size_mb  = $logSizeMb
            db_size_mb   = $dbSizeMb
            bak_size_mb  = $bakSizeMb
            compression  = $compression
            status       = "OK"
            copied       = $true
            copy_method  = "FreeFileSyncPortable"
            work_dir     = $freeWorkDir
          }

          $meta | ConvertTo-Json -Depth 5 | Out-File "$metaDir\$db.json" -Encoding UTF8

          Write-BackupStatus "done" "✅ Завершено" $db

          Remove-Item $backupFile -Force -ErrorAction SilentlyContinue
          Remove-Item $syncFile -Force -ErrorAction SilentlyContinue
          Remove-Item "$freeWorkDir\sync.ffs_lock" -Force -ErrorAction SilentlyContinue
          Remove-Item "$freeWorkDir\Data\sync.ffs_lock" -Force -ErrorAction SilentlyContinue
          Remove-Item "$ffsDir\Data\sync.ffs_lock" -Force -ErrorAction SilentlyContinue

          Write-Host "Backup created locally: $backupFile"
          Write-Host "Backup copied to server: $remoteBak"
          Write-Host "Remote backup verified"
          Write-Host "Time fixed: $now"
          Write-Host "Meta created: $metaDir\$db.json"

          exit 0
        }
        catch {
          try {
            if ($db) {
              Write-BackupStatus "error" "❌ Ошибка" $db
            } else {
              Write-BackupStatus "error" "❌ Ошибка" "unknown_{{ inventory_hostname }}"
            }
          } catch {}

          Write-Host "BACKUP ERROR on {{ inventory_hostname }}: $($_.Exception.Message)"
          exit 1
        }
        finally {
          Remove-Item "C:\FREE\sync.ffs_lock" -Force -ErrorAction SilentlyContinue
          Remove-Item "C:\FREE\Data\sync.ffs_lock" -Force -ErrorAction SilentlyContinue
          Remove-Item "C:\FREE\FreeFileSyncPortable\Data\sync.ffs_lock" -Force -ErrorAction SilentlyContinue
          cmd /c "net use {{ backup_share }} /delete /y >nul 2>&1"
        }
      ignore_errors: yes
      ignore_unreachable: yes
