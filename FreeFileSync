---
- name: Install FreeFileSync via Scheduled Task
  hosts: all
  gather_facts: no

  tasks:
    - name: Install FreeFileSync if missing
      ansible.windows.win_shell: |
        New-Item -ItemType Directory -Path "C:\TEMPO" -Force | Out-Null

        $ffs = "C:\Program Files\FreeFileSync\FreeFileSync.exe"
        if (!(Test-Path $ffs)) {
          $ffs = "C:\Program Files (x86)\FreeFileSync\FreeFileSync.exe"
        }

        if (!(Test-Path $ffs)) {
          $installer = "C:\TEMPO\FreeFileSync_14.9_Windows_Setup.exe"
          $installerUrl = "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/FreeFileSync_14.9_Windows_Setup.exe"

          if (!(Test-Path $installer)) {
            Invoke-WebRequest -Uri $installerUrl -OutFile $installer -UseBasicParsing
          }

          $cmd = "`"$installer`" /VERYSILENT /SUPPRESSMSGBOXES /NORESTART /SP-"

          schtasks /Delete /TN "InstallFreeFileSync" /F 2>$null

          schtasks /Create `
            /TN "InstallFreeFileSync" `
            /SC ONCE `
            /ST 23:59 `
            /TR $cmd `
            /RL HIGHEST `
            /RU "admin" `
            /RP "Pharmacia_" `
            /F

          schtasks /Run /TN "InstallFreeFileSync"

          Start-Sleep -Seconds 90
        }

        $ffs = "C:\Program Files\FreeFileSync\FreeFileSync.exe"
        if (!(Test-Path $ffs)) {
          $ffs = "C:\Program Files (x86)\FreeFileSync\FreeFileSync.exe"
        }

        if (!(Test-Path $ffs)) {
          throw "FreeFileSync installation failed"
        }

        schtasks /Delete /TN "InstallFreeFileSync" /F 2>$null

        Write-Host "FreeFileSync installed/found: $ffs"
