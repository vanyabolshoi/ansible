---
- name: Deploy Portable FreeFileSync
  hosts: all
  gather_facts: no

  tasks:
    - name: Deploy portable FreeFileSync if missing
      ansible.windows.win_shell: |
        New-Item -ItemType Directory -Path "C:\TEMPO" -Force | Out-Null

        $ffsDir = "C:\Program Files\FreeFileSync"
        $ffsExe = "$ffsDir\FreeFileSync.exe"

        if (!(Test-Path $ffsExe)) {

          Write-Host "FreeFileSync not found. Deploying portable version..."

          $zip = "C:\TEMPO\FreeFileSync.zip"
          $url = "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/FreeFileSync.zip"

          if (Test-Path $zip) {
            Remove-Item $zip -Force -ErrorAction SilentlyContinue
          }

          Invoke-WebRequest `
            -Uri $url `
            -OutFile $zip `
            -UseBasicParsing

          if (!(Test-Path $zip)) {
            throw "FreeFileSync.zip was not downloaded"
          }

          if (Test-Path $ffsDir) {
            Remove-Item $ffsDir -Recurse -Force -ErrorAction SilentlyContinue
          }

          New-Item -ItemType Directory -Path $ffsDir -Force | Out-Null

          Expand-Archive `
            -Path $zip `
            -DestinationPath $ffsDir `
            -Force

          Start-Sleep -Seconds 3
        }

        $ffsExe = "C:\Program Files\FreeFileSync\FreeFileSync.exe"

        if (!(Test-Path $ffsExe)) {
          $found = Get-ChildItem "C:\Program Files\FreeFileSync" -Recurse -Filter "FreeFileSync.exe" -ErrorAction SilentlyContinue | Select-Object -First 1

          if ($found) {
            Write-Host "FreeFileSync found in subfolder: $($found.FullName)"
          } else {
            throw "FreeFileSync.exe not found after unzip"
          }
        } else {
          Write-Host "FreeFileSync installed/found: $ffsExe"
        }
