---

* name: Install ECR ActiveX Library (stable)
  hosts: all
  gather_facts: no

  vars:
  installer_url: "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/ECR_ActiveX_Library_x64_v.1.10.6.2.exe"
  installer_path: "C:\Temp\ECR_ActiveX_Library_x64_v.1.10.6.2.exe"

  tasks:

  * name: Ensure Temp directory exists
    ansible.windows.win_file:
    path: C:\Temp
    state: directory

  * name: Download installer
    ansible.windows.win_get_url:
    url: "{{ installer_url }}"
    dest: "{{ installer_path }}"
    force: true

  * name: Run installer in background
    ansible.windows.win_shell: |
    Start-Process -FilePath "{{ installer_path }}" -ArgumentList "/S /NORESTART" -WindowStyle Hidden

  * name: Wait for installation to complete
    ansible.windows.win_wait_for:
    timeout: 60

  * name: Ensure installer is released before cleanup
    ansible.windows.win_shell: |
    Start-Sleep -Seconds 10

  * name: Cleanup installer (safe)
    ansible.windows.win_file:
    path: "{{ installer_path }}"
    state: absent
