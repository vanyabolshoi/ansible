---
- name: Install ECR ActiveX Library (MSI/Package mode)
  hosts: all
  gather_facts: no

  vars:
    installer_url: "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/ECR_ActiveX_Library_x64_v.1.10.6.2.exe"
    installer_path: "C:\\Temp\\ECR_ActiveX_Library_x64_v.1.10.6.2.exe"
    install_log: "C:\\Temp\\ecr_install.log"

  tasks:

    - name: Ensure Temp directory exists
      ansible.windows.win_file:
        path: C:\Temp
        state: directory

    - name: Download installer
      ansible.windows.win_get_url:
        url: "{{ installer_url }}"
        dest: "{{ installer_path }}"
        force: true

    - name: Install via win_package (preferred method)
      ansible.windows.win_package:
        path: "{{ installer_path }}"
        state: present
        arguments: "/S /NORESTART"
      register: install_result
      failed_when: install_result.failed is defined and install_result.failed

    - name: Wait for installation stabilization
      ansible.windows.win_shell: |
        Start-Sleep -Seconds 10

    - name: Verify installation (Registry CLSID check)
      ansible.windows.win_shell: |
        $result = Get-ChildItem HKCR:\CLSID -ErrorAction SilentlyContinue |
        Get-ItemProperty -ErrorAction SilentlyContinue |
        Where-Object { $_.PSObject.Properties.Value -match "ECR" }

        if ($result) {
          "ECR_FOUND"
        } else {
          "NOT_FOUND"
        }
      register: clsid_check

    - name: Show result
      ansible.builtin.debug:
        msg: "{{ clsid_check.stdout }}"
