---
- name: Install ECR via BAT script
  hosts: all
  gather_facts: no

  vars:
    installer_url: "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/ECR_ActiveX_Library_x64_v.1.10.6.2.exe"
    bat_url: "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/install_ecr.bat"

    installer_path: "C:\\Temp\\ECR_ActiveX_Library_x64_v.1.10.6.2.exe"
    bat_path: "C:\\Temp\\install_ecr.bat"

  tasks:

    - name: Ensure Temp directory exists
      ansible.windows.win_file:
        path: C:\Temp
        state: directory

    - name: Download ECR installer
      ansible.windows.win_get_url:
        url: "{{ installer_url }}"
        dest: "{{ installer_path }}"
        force: true

    - name: Download BAT installer script
      ansible.windows.win_get_url:
        url: "{{ bat_url }}"
        dest: "{{ bat_path }}"
        force: true

    - name: Run BAT as Administrator
      ansible.windows.win_shell: |
        Start-Process -FilePath "{{ bat_path }}" -Verb RunAs -Wait
