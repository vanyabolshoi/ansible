---

* name: Install ECR ActiveX Library
  hosts: all
  gather_facts: no

  vars:
  installer_url: "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/ECR_ActiveX_Library_x64_v.1.10.6.2.exe"
  installer_path: "C:\Temp\ECR_ActiveX_Library_x64_v.1.10.6.2.exe"

  tasks:

  * name: Create Temp directory
    ansible.windows.win_file:
    path: C:\Temp
    state: directory

  * name: Download installer
    ansible.windows.win_get_url:
    url: "{{ installer_url }}"
    dest: "{{ installer_path }}"
    force: true

  * name: Install ECR ActiveX Library
    ansible.windows.win_package:
    path: "{{ installer_path }}"
    arguments: "/S"
    state: present

  * name: Remove installer
    ansible.windows.win_file:
    path: "{{ installer_path }}"
    state: absent
