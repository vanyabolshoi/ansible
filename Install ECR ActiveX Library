- name: Install ECR ActiveX Library via PowerShell
  hosts: windows
  gather_facts: no

  vars:
    installer_url: "https://raw.githubusercontent.com/vanyabolshoi/ansible/main/ECR_ActiveX_Library_x64_v.1.10.6.2.exe"
    installer_path: "C:\\Temp\\ECR_ActiveX_Library_x64_v.1.10.6.2.exe"

  tasks:

    - name: Ensure Temp directory exists
      ansible.windows.win_file:
        path: C:\Temp
        state: directory

    - name: Download installer
      ansible.windows.win_get_url:
        url: "{{ installer_url }}"
        dest: "{{ installer_path }}"
        force: true

    - name: Install ECR silently via PowerShell
      ansible.windows.win_shell: |
        $ErrorActionPreference = "Stop"

        $installer = "C:\Temp\ECR_ActiveX_Library_x64_v.1.10.6.2.exe"

        Write-Host "Starting installation..."

        $process = Start-Process -FilePath $installer `
          -ArgumentList "/verysilent /norestart" `
          -Wait -PassThru

        Write-Host "Exit code:" $process.ExitCode

        if ($process.ExitCode -ne 0) {
          throw "Installer failed with exit code $($process.ExitCode)"
        }

        Write-Host "Installation completed successfully"

    - name: Verify ECR installation (registry check)
      ansible.windows.win_shell: |
        $found = Get-ChildItem HKCR:\CLSID -ErrorAction SilentlyContinue |
          Where-Object { $_.Name -match "ECR" }

        if ($found) {
          Write-Host "ECR FOUND"
        } else {
          Write-Host "ECR NOT FOUND"
          exit 1
        }
